# Copy to .env and fill in. All values are optional except where noted.

# Claude API key — enables the NLP interpretation layer (summaries, requirements,
# obligations, risk scoring, corpus Q&A). Without it, ingest + semantic search
# still work; interpretation is skipped. Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Model used for interpretation. Opus for depth, Sonnet for speed/cost.
REGINTEL_MODEL=claude-opus-4-6

# Root folder of the regulatory document corpus to ingest.
# Defaults to the parent of the platform/ directory (your existing PDF library).
REGINTEL_CORPUS_ROOT=

# Local embedding model (fastembed / ONNX). Small = fast on CPU.
REGINTEL_EMBED_MODEL=BAAI/bge-small-en-v1.5

# SQLite database path (defaults to platform/backend/data/regintel.db)
REGINTEL_DB_PATH=

# Auto-ingest: re-scan the corpus folder every N minutes so newly added files
# appear automatically. 0 disables it (the Sync button and CLI still work).
REGINTEL_AUTOINGEST_MINUTES=15
# Also run Claude interpretation on newly added docs during scheduled sync
# (only when ANTHROPIC_API_KEY is set; can add cost). Off by default.
REGINTEL_AUTOINGEST_INTERPRET=false
